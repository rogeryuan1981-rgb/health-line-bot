# 1. 建立專案主資料夾並進入
mkdir health-line-bot
cd health-line-bot

# 2. 初始化 Git 版本控制
git init

# 3. 建立後端與前端的基礎資料夾
mkdir functions
mkdir admin-panel

# 4. 建立一份基礎的 .gitignore 檔案 (忽略 node_modules 與環境變數檔)
echo "node_modules/" > .gitignore
echo ".env" >> .gitignore
echo ".DS_Store" >> .gitignore

# 5. 提交第一次 commit
git add .
git commit -m "chore: 初始化專案結構"

# 6. 連結您的 GitHub 儲存庫並推送到主分支
# ⚠️ 請將下方的 <您的GitHub帳號> 替換為您的實際帳號
git branch -M main
git remote add origin https://github.com/<您的GitHub帳號>/health-line-bot.git
git push -u origin main
