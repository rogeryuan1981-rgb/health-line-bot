{
  "name": "health-bot-functions",
  "description": "預防保健客服 LINE Webhook 後端邏輯",
  "engines": {
    "node": "18"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@line/bot-sdk": "^8.2.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^18.11.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
